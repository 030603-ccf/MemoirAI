*.mp3
*.wav
*.m4a
*.flac
*.ogg
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.webp
*.pdf
!frontend/src/assets/*

# Model files (user downloads separately)
models/
*.bin
*.safetensors
*.pt
*.pth
*.onnx
*.h5
*.pkl
*.pyd

# Local config
config.local.*
*.local.json

# PyInstaller (allow *.spec — needed for build)
# *.spec  (kept in git)
# build/, dist/ (gitignored above)

# Local development files
.tmp/
tmp/
temp/
*.tmp
*.bak
*.orig
*.swp

# OpenCode (local AI agent runtime, not part of the project)
.opencode/

