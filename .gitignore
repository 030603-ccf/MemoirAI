# Project data (user generated - NEVER commit)
data/
!data/.gitkeep
!data/user_settings.example.json

# Specifically protect the user-private skill directory
# (it can contain personal catchphrases, persona data, and conversation analysis)
data/skills/000_profile.skill
data/skills/005_insights.skill
# Allow the bootstrap process to add new template copies on first run
!data/skills/.gitkeep

